# Copy this file to .env and set your value.

# ThoughtSpot instance URL (e.g. https://my-org.thoughtspot.cloud)
# Used by the SDK (init) and the dev-server token endpoint.
# Sign-in credentials are entered at the login page, NOT stored here.
VITE_THOUGHTSPOT_HOST=https://your-instance.thoughtspot.cloud

# Optional content IDs for the Embed Studio surface.
# AppEmbed needs none. Search/Spotter fall back to the worksheet GUID below.
# VITE_TS_LIVEBOARD_ID=
# VITE_TS_DATASOURCE_ID=
# VITE_TS_WORKSHEET_ID=cd252e5c-b552-49a8-821d-3eadaa049cca
