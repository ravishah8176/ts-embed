# Copy this file to .env and fill in your values

# Your ThoughtSpot instance URL (e.g. https://my-org.thoughtspot.cloud)
VITE_THOUGHTSPOT_HOST=https://your-instance.thoughtspot.cloud

# Credentials for AuthType.Basic (dev/testing only — never use in production)
VITE_TS_USERNAME=your-username
VITE_TS_PASSWORD=your-password

# Worksheet / Datasource GUID for Spotter embed
VITE_TS_DATASOURCE_ID=your-worksheet-guid-here

# Liveboard GUID (optional, for liveboard embed demo)
VITE_TS_LIVEBOARD_ID=your-liveboard-guid-here
