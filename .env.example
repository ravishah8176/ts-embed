# ThoughtSpot Embed Studio — environment variables
# Copy this file to `.env` (or `.env.local`) and adjust as needed.
# All variables are optional; sensible defaults are applied in src/studio/config.ts.
# Only VITE_-prefixed vars are exposed to the client bundle.

# ThoughtSpot cluster host (https://…, no trailing slash).
# Usually left blank — the login form collects the host and the dev server
# (vite.config.ts) creates the session against it. Set this only to pre-fill a
# default host. Example: https://my-company.thoughtspot.cloud
VITE_THOUGHTSPOT_HOST=

# GUID of the Liveboard shown by the Liveboard embed.
VITE_TS_LIVEBOARD_ID=

# GUID of the data source (worksheet/model) used by the Search embed.
# Defaults to cd252e5c-b552-49a8-821d-3eadaa049cca
VITE_TS_DATASOURCE_ID=

# GUID of the worksheet/model bound to the Spotter and Search embeds.
# Defaults to cd252e5c-b552-49a8-821d-3eadaa049cca
VITE_TS_WORKSHEET_ID=

# URL of the hosted ThoughtSpot REST API playground embedded by the REST API tab.
# Defaults to https://rest-api-kg1tc3osg-thoughtspot-site.vercel.app/
VITE_REST_PLAYGROUND_URL=
